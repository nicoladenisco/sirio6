<div class="col-sm-6 col-md-4">
  <div class="card border-${stile1} mb-3">
    <div class="card-header text-bg-${stile1}">
      ${t.idTask} - ${t.taskName}
    </div>
    <div class="card-body">
      <SPAN class="txt-green-bold-18-nul">${t.descrizione}</SPAN><br>
      <SPAN class="txt-black-bold-12">Utente: ${nomeUtente}</SPAN><br>
      <SPAN class="txt-black-bold-12">Stato: ${t.descState}</SPAN><br>
      #if($t.getTaskState() == 1) ## Task.ST_RUNNING
      <SPAN class="txt-black-bold-12">Avviato alle: ${tinizio} </SPAN><br>
      <SPAN class="txt-black-bold-12">Tempo trascorso: ${tempo1} secondi</SPAN><br>
      #else
      <SPAN class="txt-black-bold-12">Completato alle: ${tfine} </SPAN><br>
      <SPAN class="txt-black-bold-12">Tempo impiegato: ${tempo2} secondi</SPAN><br>
      #end
      <SPAN class="txt-black-regular-10">${t.messaggio}</SPAN><br>

      <SPAN class="txt-black-regular-10">${t.htmlDesc}</SPAN><br>

      #set($strPerc = "${t.perc}%")

      <DIV style="padding-top: 10px">
        <div class="progress ${stile2}">
          <div class="progress-bar" role="progressbar" aria-valuenow="2" aria-valuemin="0" aria-valuemax="100"
               style="min-width: 2em; width: $strPerc;">
            ${t.perc}%
          </div>
        </div>
      </DIV>

      <div style="margin-top: 10px;">
        <center>
          #if($t.getTaskState() == 1) ## Task.ST_RUNNING
          <INPUT class="btn btn-primary" type="button" value="Interrompi" onclick="interrompi(${t.idTask})">
          #else
          <INPUT class="btn btn-outline-secondary" type="button" value="Rimuovi" onclick="rimuovi(${t.idTask})">
          #if($t.isProdFiles())
          <INPUT class="btn btn-primary" type="button" value="Download" onclick="apriDownload(${t.idTask})">
          #end
          #end          

          #if($t.getTaskState() == 3) ## Task.ST_ERROR
          <INPUT class="btn btn-danger" type="button" value="Errori" onclick="apriErrori(${t.idTask})">
          #end
        </center>
      </div>

    </div>
  </div>
</div>
